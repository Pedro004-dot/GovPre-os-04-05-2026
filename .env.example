# URL pública do backend GovPreços (não é segredo — a landing só faz GET de conteúdo publicado).
# Local: http://localhost:3001 · Produção: a URL do backend (ex: https://api.govprecos.com.br)
# Configure também na Vercel (Project Settings → Environment Variables).
VITE_API_URL=http://localhost:3001

# URL da newsletter Sessão Pública (link externo).
# Se vazio, o CTA da newsletter não aparece no hero Em Pauta.
VITE_NEWSLETTER_URL=https://exemplo.beehiiv.com/subscribe
